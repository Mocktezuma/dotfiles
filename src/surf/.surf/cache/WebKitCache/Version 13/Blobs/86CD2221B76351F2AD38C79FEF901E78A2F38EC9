        this.p_time1 = null;


        this.Timers = [];
        this.i_animationind = 0;
        RCSS.Clear_i_AnimCss(this.name);

        if (px2sec > 0)
            this.RestoreAnimations();
        
        var completedAnimEvents = []; // animation list which are passed from selected time.
        var currentAnimEvents = []; // animation list for thier execution in between the selected time. 
        var previousEvtLeft = 0; //
        var isNextPlay = false;

        for (var i = 0; i < this.events.length; i++) {

            var evt = this.events[i];
            // Find first event which right side of the tick select
            if (evt.startTime > px2sec) {
                this.i_animationind = i;
                evt.playmode = evt.startTime - px2sec; //ScaleUtil.PxToTime((evt.sLeft - sX));
                this.updateDelay(evt, '');
                evt.generateCss();
                previousEvtLeft = evt.startTime;
                isNextPlay = true;
                break;
            }

            if (evt.startTime <= px2sec && evt.endTime > px2sec)
                currentAnimEvents.push(evt);
            else if (evt.endTime <= px2sec)
                completedAnimEvents.push(evt);
        }


        //if (isNextPlay == false)
        //this.i_animationind = this.events.length;

        //this.i_animationind = 0;


        // Set End Frame 
        for (var j = 0; j < completedAnimEvents.length; j++) {
            completedAnimEvents[j].SetEndFrame();
        }

        // Generate Css For Underlying Animation 
        for (var j = 0; j < currentAnimEvents.length; j++) {
            this.updateDelay(currentAnimEvents[j], px2sec);
            currentAnimEvents[j].generateCss();

        }

        // Generate css for animation which are right side of the tickselect and update thier playmode
        if (isNextPlay == true) {
            for (var i = (this.i_animationind + 1) ; i < this.events.length; i++) {

                var evt = this.events[i];

                evt.playmode = (evt.startTime - previousEvtLeft);
                previousEvtLeft = evt.startTime;

                this.updateDelay(evt, '');
                evt.generateCss();

            }
        }

        RCSS.Reg_i_AnimCss(this.i_style);

        // Execute Animation which is in between the tickselect 
        for (var j = 0; j < currentAnimEvents.length; j++) {
            currentAnimEvents[j].execute();
        }
        this.status = "Running";
        PL.oInteractive = this;
        if (DisSeekBar) {
            if (this.seekbar == "Yes") {
                //this.oSB.restore();
                this.oSB.execute(px2sec, this.endTime);
            }
            //else {
            //  SeekBar.restore();
            //}
        }

        if (isNextPlay == true) {
            this.animate();
        }

