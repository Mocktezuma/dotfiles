        if (evt.type == 'pagechange') {
            evt.configure();
        }
        else if (evt.type == 'show' || evt.type == 'hide') {
            evt.configure();
        }
        else if (evt.type == 'cssanim') {
            evt.configure();
        }
        else if (evt.type == 'spriteanim') {
            evt.configure();
        }
        else if (evt.type == 'advmsk') {
            evt.configure();
        }
        else if (evt.type == 'sound') {
            evt.configure();
        }
