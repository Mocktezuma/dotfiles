                var x = (this.duration * i) / this.delay;
                if (x > 1) {
                    this.delay = this.delay - (this.duration * (i - 1));
                    loopcount = this.loop - (i - 1);
                    break;
                }
            }

        }
        var duration = 0;
        if (ScaleUtil.TFR(this.duration) > 0.10)
