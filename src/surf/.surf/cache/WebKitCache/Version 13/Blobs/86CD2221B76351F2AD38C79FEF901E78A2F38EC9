}function EndInteractivity() {
    this.type = "endinteractivity";
    this.tagname = "";
    this.duration = 0;
    this.etype = "";
    this.time = new Date().getTime();
    this.pageno = 1;
    this.playmode = "";
    this.interactivename = "";
    this.status = "I";
    //
    this.duration = 0.1;
    this.startTime = 0;
    this.endTime = 0;
    this.delay = 0;
    this.playstate = 'running';
    this.animstate = "E";
    this.loop = 1;


    this.initobj = function (evt) {
        this.tagname = "";
        this.duration = 0;
        this.etype = evt[1];
        this.time = new Date().getTime();
        this.pageno = evt[2];
        this.playmode = evt[0];
        this.interactivename = evt[3];
        this.startTime = evt[4];
        this.endTime = evt[5];
    }
    this.execute = function () {
        this.status = "E";

        var ocInteractivityObj = PL.getInteractivityObj(this.interactivename);

        if (ocInteractivityObj == undefined || ocInteractivityObj == null) return;

        if (ocInteractivityObj.oSB != null)
            ocInteractivityObj.oSB.DisablePause();

        if (ocInteractivityObj.loopcount > ocInteractivityObj.curLoop) {

            ocInteractivityObj.curLoop++;

            if (PlayerName == "BANAD")
                window.setTimeout(PL.executeInteractiveAnimation, 0, this.interactivename);
            else
                window.setTimeout(PL.executeInteractiveAnimation, 200, this.interactivename);

        }

    }
    this.updateDelay = function (currentpx) { }
    this.generateCss = function () { }
    this.restoreAnim = function () { }
    this.SetEndFrame = function () { }
    this.restore = function () { }


}
