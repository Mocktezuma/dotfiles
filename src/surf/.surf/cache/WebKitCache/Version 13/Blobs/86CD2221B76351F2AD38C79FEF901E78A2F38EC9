    this.calcIEndTime = function () {

        var evtDuration = new Array();
        var totatPlayMode = 0;
        var maxDuration = 0;
        var PlayTime = 0;
        for (var i = 0; i < this.events.length; i++) {

            var evt = this.events[i];
            PlayTime = PlayTime + parseFloat(evt.playmode);
            evt.startTime = PlayTime;
            evt.endTime = parseFloat(evt.startTime) + parseFloat(evt.duration) * parseFloat(evt.loop);

            ///
