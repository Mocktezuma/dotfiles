window.RCSS = {
    Cssdata: [],
    Pageno: [],
    AddCssInfo: function (cssData, PageNo) {

        var pnofound = false
        for (var i = 0; i < RCSS.Pageno.length; i++) {

            if (RCSS.Pageno[i] == PageNo) {
                pnofound = true
                RCSS.Cssdata[i] = RCSS.Cssdata[i] + "\n " + cssData;
                break;
            }
        }
        if (pnofound == false) {

            RCSS.Cssdata.push(cssData);
            RCSS.Pageno.push(PageNo);
        }

    },

    getInlineCSS: function (animname, duration, loop, timingfunction, delay, animationfillmode) {
        var oCSSBuilder = "";
        oCSSBuilder += "." + animname + " {";
        if (BR.name == "chrome" || BR.name == "safari") {
            oCSSBuilder += "-webkit-animation: " + animname + " " + duration + "s " + timingfunction + " " + delay + "s " + loop + " " + animationfillmode + ";";
        }
        else if (BR.name == "firefox") {
            oCSSBuilder += "-moz-animation: " + animname + " " + duration + "s " + timingfunction + " " + delay + "s " + loop + " " + animationfillmode + ";";
        }
        else if (BR.name == "ie" || BR.name.toLowerCase() == "netscape") {
            oCSSBuilder += "animation: " + animname + " " + duration + "s " + timingfunction + " " + delay + "s " + loop + " " + animationfillmode + ";";
        }
        else if (BR.name == "opera") {
            oCSSBuilder += "-o-animation: " + animname + " " + duration + "s " + timingfunction + " " + delay + "s " + loop + " " + animationfillmode + ";";
        }
        else {
            oCSSBuilder += "animation: " + animname + " " + duration + "s " + timingfunction + " " + delay + "s " + loop + " " + animationfillmode + ";";
        }
        oCSSBuilder += "}";
        return oCSSBuilder;
    },

    RegisterCSSToPage: function () {

        for (var p = 0; p < RCSS.Pageno.length; p++) {

            //var iframedoc = document.getElementById("frPage" + RCSS.Pageno[p].toString()); //window.frames["frPage" + RCSS.Pageno[p].toString()].window.document;
            var xeHead = document.getElementsByTagName('head');
            styleNode = document.createElement('style');
            styleNode.setAttribute('type', 'text/css');
            styleNode.innerHTML = "\n" + RCSS.Cssdata[p].toString();
            xeHead[0].appendChild(styleNode);
        }


        RCSS.Cssdata = [];
        RCSS.Pageno = [];
    }

};





