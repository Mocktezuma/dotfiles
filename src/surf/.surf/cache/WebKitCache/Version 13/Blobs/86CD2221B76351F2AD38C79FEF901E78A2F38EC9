    events: [],
    uniqueid:0,
    fillevents: function (isPageLoad) {

        var myJosnObject = pjsondata;

        PL.events = [];

        for (var j = 0; j < myJosnObject.events.length; j++) {
            var webevent = myJosnObject.events[j];

            var webobj = PL.ConvertEventJsonToObj(webevent);

            if ((isPageLoad == 'Y' && webobj.etype != 'pl') || (isPageLoad == 'N' && webobj.etype == 'pl')) continue;

            PL.events.push(webobj)
        }

    },
    ConvertEventJsonToObj: function (webevent) {
        var webobj = null;
        if (webevent[0] == "sw") {
            webobj = new ShowA();
        }
        else if (webevent[0] == "hd") {
            webobj = new HideA();
        }
        else if (webevent[0] == "pc") {
            webobj = new PagechangeA();
        }
        else if (webevent[0] == "sd") {
            webobj = new SoundA();
        }
        else if (webevent[0] == "csa") {
            webobj = new CSSAnimation();
        }
