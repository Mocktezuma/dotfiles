function CssKeyframeRules() {
    this.translateX = "";
    this.translateY = "";
    this.height = "";
    this.width = "";
    this.opacity = "";
    this.backColor = "";
    this.color = "";
    this.step = "";
    this.scaleX = "";
    this.scaleY = "";
    this.rotaionX = "";
    this.rotaionY = "";
    this.rotaionZ = "";
    this.prespective = "";
    this.originValue = "";
    this.clipLeft = "";
    this.clipTop = "";
    this.clipRight = "";
    this.clipBottom = "";
    this.ruleobj = "";

    this.initCssRule = function (rule) {
        this.step = rule.step;
        if (rule.tX != undefined)
            this.translateX = rule.tX;
        if (rule.tY != undefined)
            this.translateY = rule.tY;
        if (rule.h != undefined)
            this.height = rule.h;
        if (rule.w != undefined)
            this.width = rule.w;
        if (rule.sX != undefined)
            this.scaleX = rule.sX;
        if (rule.sY != undefined)
            this.scaleY = rule.sY;
        if (rule.rX != undefined)
            this.rotaionX = rule.rX;
        if (rule.rY != undefined)
            this.rotaionY = rule.rY;
        if (rule.rZ != undefined)
            this.rotaionZ = rule.rZ;
        if (rule.presp != undefined)
            this.prespective = rule.presp;
        if (rule.orgV != undefined)
            this.originValue = rule.orgV;
        if (rule.opc != undefined)
            this.opacity = rule.opc;
        if (rule.bClr != undefined)
            this.backColor = rule.bClr;
        if (rule.cL != undefined)
            this.clipLeft = rule.cL;
        if (rule.cT != undefined)
            this.clipTop = rule.cT;
        if (rule.cR != undefined)
            this.clipRight = rule.cR;
        if (rule.cB != undefined)
            this.clipBottom = rule.cB;
        if (rule.clr != undefined)
            this.color = rule.clr;
    }

    this.generateCssRule = function () {

        var ruleBuilder = "";

        if (this.height != "")
            ruleBuilder += 'height:' + this.height + 'px;';

        if (this.width != "")
            ruleBuilder += 'width:' + this.width + 'px;';

        if (this.color != "")
            ruleBuilder += 'color:' + this.color + ';';

        if (this.backColor != "")
            ruleBuilder += 'background-color:' + this.backColor + ';';

        if (this.opacity != "")
            ruleBuilder += 'opacity:' + this.opacity + ';';

        var transform = '';

        //translate x ,y
        if (this.translateX != "" && this.translateY != "")
            transform += 'translate(' + this.translateX + 'px,' + this.translateY + 'px) ';
        else if (this.translateX != "")
            transform += 'translateX(' + this.translateX + 'px) ';
        else if (this.translateY != "")
            transform += 'translateY(' + this.translateY + 'px) ';

        if (this.originValue != "") {
            if (BR.name == "safari")
                ruleBuilder += BR.prefix + '-transform-origin:' + this.originValue + ';';
            else
                ruleBuilder += 'transform-origin:' + this.originValue + ';';
        }

        //scale x,y
        if (this.scaleX != "" && this.scaleY != "") {
            if (this.scaleX == this.scaleY)
                transform += 'scale(' + this.scaleX + ') ';
            else
                transform += 'scale(' + this.scaleX + ',' + this.scaleY + ') ';
        }
        else if (this.scaleX != "")
            transform += 'scaleX(' + this.scaleX + ') ';
        else if (this.scaleY != "")
            transform += 'scaleY(' + this.scaleY + ') ';

        //rotation prespective
        if (this.prespective != "")
            transform += 'perspective(' + this.prespective + 'px) ';

        //rotation
        if (this.rotaionX != "")
            transform += 'rotateX(' + this.rotaionX + 'deg) ';

        if (this.rotaionY != "")
            transform += 'rotateY(' + this.rotaionY + 'deg) ';

        if (this.rotaionZ != "")
            transform += 'rotateZ(' + this.rotaionZ + 'deg) ';

        if (transform != '') {
            if (BR.name == "safari")
                ruleBuilder += BR.prefix + '-transform: ' + transform;
            else
                ruleBuilder += 'transform: ' + transform;
        }

        if (this.clipLeft != "" || this.clipTop != "" || this.clipRight != "" || this.clipBottom != "")
            ruleBuilder += 'clip: rect(' + this.clipTop + 'px,' + this.clipRight + 'px,' + this.clipBottom + 'px,' + this.clipLeft + 'px);';


        return this.step + '{' + ruleBuilder + '}';
    }
    this.generateBlinkTextEndFrame = function () {
        return "{color:" + this.color + " !important}";

    }
}

