    executePageLoadFirst: function () {
        for (var i = 0; i < PL.events.length; i++) {
            if (PL.events[i].etype == 'pl')
                PL.execute(PL.events[i]);
        }

    },
    execute: function (wbevent) {
        var type = wbevent.type;
        if (type === "show" || type === "hide") {
            wbevent.execute();
        }
        else if (type == "showhidelayer") {
            wbevent.execute();
        }
    },
    configureInteractivity: function () {

        PL.fillIntractiveFrameInfo();
        PL.preprocessInteractiveEvent();
    },
    fillIntractiveFrameInfo: function () {
        var iEventsJson = pi_eventsjsondata;
        var tempIEvents = new Array();
        for (var j = 0; j < iEventsJson.i_events.length; j++) {
            var webevent = iEventsJson.i_events[j];

            var webobj = PL.ConvertEventJsonToObj(webevent);
            tempIEvents.push(webobj)
        }

        var iFrameInfoEventJson = pi_frameinfojson;

        for (var j = 0; j < iFrameInfoEventJson.i_frameinfo.length; j++) {
            var iframeevent = iFrameInfoEventJson.i_frameinfo[j];

            var oIntractive = new Interactive();
            
            oIntractive.init(iframeevent);
            oIntractive.FillInteractiveEvents(tempIEvents);

            oIntractive.calcIEndTime();
            oIntractive.AddEndInteractEvent();

            PL.i_intractive.push(oIntractive);

        }
        tempIEvents = null;
    },
    resetSingleInteractivity: function (iactivityname) {

        for (var j = 0; j < PL.i_intractive.length; j++) {
            if (PL.i_intractive[j].name != iactivityname) continue;
            PL.i_intractive[j].curLoop = 1;
            break;
        }
    },
    executeInteractiveAnimation: function (IAnimEventName) {

        var oExecuteInteractObject = PL.getInteractivityObj(IAnimEventName);
        if (oExecuteInteractObject == undefined || oExecuteInteractObject == null) return;

        //  Do not start the interactivity by user click if the opacity of target object is 0
        if (oExecuteInteractObject.eventtype != "pageload" && oExecuteInteractObject.eventtype != "custom" && oExecuteInteractObject.tagname != "") {
            var frameObj = oExecuteInteractObject.tagobj;
            if (frameObj == undefined || frameObj == null) return;
            if (CSS(frameObj.id, "opacity") == "0") return;
        }

        PL.stopGroupInteractivity(oExecuteInteractObject);
        oExecuteInteractObject.Start();

    },
    pauseInteractivity: function (iactivityname) {

        var oPauseInteractivityObj = PL.getInteractivityObj(iactivityname);
        if (oPauseInteractivityObj == undefined || oPauseInteractivityObj == null) return;

        oPauseInteractivityObj.Pause()

    },
    resumeInteractivity: function (iactivityname) {

        oResumeInteractivityObj = PL.getInteractivityObj(iactivityname);
        if (oResumeInteractivityObj == undefined || oResumeInteractivityObj == null) return;

        oResumeInteractivityObj.Resume()

    },
    stopGroupInteractivity: function (oStopGPInteractivityObj) {

        if (oStopGPInteractivityObj.groupid.trim() == "") return;

        for (var j = 0; j < PL.i_intractive.length; j++) {
            if (PL.i_intractive[j].groupid.trim() == "") continue;
            if (PL.i_intractive[j].pageno != oStopGPInteractivityObj.pageno || PL.i_intractive[j].name == oStopGPInteractivityObj.name) continue;
            if (PL.i_intractive[j].groupid != oStopGPInteractivityObj.groupid) {
                if (PL.i_intractive[j].groupid.indexOf(',') != -1) {
                    var loopGroupid = PL.i_intractive[j].groupid.split(',')[0];
                    if (loopGroupid != oStopGPInteractivityObj.groupid) continue;
                }
                else
                    continue;
            }
            PL.i_intractive[j].Stop();
        }

    },
    stopInteractivity: function (iactivityname, iactivityObject) {
        var oStopInteractivityObj;
        if (iactivityname.trim() != "")
            oStopInteractivityObj = PL.getInteractivityObj(iactivityname);
        else
            oStopInteractivityObj = iactivityObject;

        if (oStopInteractivityObj == undefined || oStopInteractivityObj == null) return;

        oStopInteractivityObj.Stop()

    },
    stopSourcePageInteractivity: function (pageno) {
        var iActivities = [];
        for (var j = 0; j < PL.i_intractive.length; j++) {
            if (PL.i_intractive[j].pageno != pageno) continue;
            iActivities.push(PL.i_intractive[j]);
        }

        for (var i = 0; i < iActivities.length; i++)
            PL.stopInteractivity("", iActivities[i]);

        // Start target Page Interactivity
    },
    startPageLoadInteractivity: function (targetpageno) {
        var onPageLoadInt = PL.getonPLoaddInteractivity(targetpageno);
        if (onPageLoadInt != undefined && onPageLoadInt != null && onPageLoadInt.trim() != "") {
            PL.executeInteractiveAnimation(onPageLoadInt);
        }
    },
    pauseAnimation: function () {
        PL.status = "paused";
        for (var t = 0; t < PL.i_intractive.length; t++) {
            var objInteractive = PL.i_intractive[t];
            if (objInteractive.status != "Running") continue;
            objInteractive.Pause();
        }

    },
    resumeAnimation: function () {
      
        PL.status = "Running";
        for (var t = 0; t < PL.i_intractive.length; t++) {
            var objInteractive = PL.i_intractive[t];
            if (objInteractive.status != "paused") continue;
            objInteractive.Resume();
        }
    },
};

