                eplaymode = 0;
            eplaymode = parseFloat(eplaymode);


            //console.log("eplaymode=" + eplaymode + " duration=" + evt.duration +" type="+ evt.type);
            totatPlayMode = totatPlayMode + eplaymode;

            if (evt.duration != undefined)
                eduration = parseFloat(evt.duration);

            eduration = parseFloat(eduration);

            eduration = parseFloat(totatPlayMode + eduration);
            evtDuration.push(eduration);

            //if (maxDuration < eduration)
            //  maxDuration = eduration;
        }

        for (var i = 0; i < evtDuration.length; i++) {
            if (evtDuration[i] > maxDuration) {
                maxDuration = evtDuration[i];
            }
        }
        evtDuration = [];

        if (this.events.length > 0)
            this.endTime = maxDuration;

        this.iplaymode = maxDuration - totatPlayMode;
        this.istart_time = maxDuration;
