//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ SCALE UTIL CLASS ~~~~~~~~~~~~~~~~~~~~~~~~~

window.ScaleUtil =
    {
        interval: 10,
        fragments: 14400,
        frameRate: 24,
        oneFrame: 41.666,
        AnimFrameRate: 24,
        AnimMute: false,
        TFR: function (Time) {
            Time = (Time * ScaleUtil.frameRate) / ScaleUtil.AnimFrameRate;
            return Time;

        },
        TFR_STEPS: function (Time) {
            return (ScaleUtil.TFR(Time) * 24);

        },
        TimeToPx: function (Time) {
            return ScaleUtil.ConvertToframePixel(ScaleUtil.interval * ScaleUtil.frameRate * Time);
        },

        PxToTime: function (Px) {
            return ScaleUtil.ConvertToframeTime(Px / (ScaleUtil.interval * ScaleUtil.frameRate));
        },

        ConvertToframeTime: function (Time) {

            var NoOfFrames = (Time * 1000 / ScaleUtil.oneFrame);

            if (String(NoOfFrames).indexOf('.') != -1) {
                var f1 = parseInt(String(NoOfFrames).split('.')[0])
                var f2 = String(NoOfFrames).split('.')[1]

                var x = parseInt(f2.substring(0, 1));
                if (x >= 7) {
                    f1 = f1 + 1;
                }

                return ScaleUtil.FrameToTime(f1);
            }
            else {
                return ScaleUtil.FrameToTime(NoOfFrames);;
            }

        },

        ConvertToframePixel: function (Pixel) {

            var Val = (Pixel / ScaleUtil.interval);

            if (String(Val).indexOf('.') != -1) {
                var Px1 = parseInt(String(Val).split('.')[0])
                var Px2 = String(Val).split('.')[1]

                var x = parseInt(Px2.substring(0, 1));
                if (x >= 7) {
                    Px1 = Px1 + 1;
                }

                return ScaleUtil.FrameRateToPx(Px1);
            }
            else {
                return ScaleUtil.FrameRateToPx(Val);
            }

        },

        FrameRateToPx: function (frame) {
            return frame * ScaleUtil.interval;
        },

        PxToFrameRate: function (px) {
            return px / ScaleUtil.interval;
        },

        FrameToTime: function (NoOfFrame) {
            return (NoOfFrame / ScaleUtil.frameRate);

        },

        TimeToFrame: function (Time) {
            return (Time * ScaleUtil.frameRate);
        },

        DrawScale: function () {


            var DivFrag = document.createElement("div")
            DivFrag.setAttribute("class", "tick major");
            DivFrag.style.left = '0px';
            DivFrag.innerHTML = 0;
            Timeline.divTopRuler.appendChild(DivFrag);

            var pix = 0;
            var j = 0;
            for (var i = 0; i < ScaleUtil.fragments; i++) {

                var DivFrag = document.createElement("div")
                if (j == 3)
                    DivFrag.setAttribute("class", "tick minor");

                else if (j == 5) {
                    DivFrag.setAttribute("class", "tick major");
                    DivFrag.innerHTML = (i);
                    j = 0;
                }
                else
                    DivFrag.setAttribute("class", "tick micro");

                DivFrag.style.left = pix + 'px';
                Timeline.divTopRuler.appendChild(DivFrag);
                j++;

                pix = pix + ScaleUtil.interval;
            }

            var ruleLen = (pix + 10) + 'px';

            Timeline.divTopRuler.style.width = ruleLen;
            Timeline.scalebar.style.width = ruleLen;
            Timeline.animationContainer.style.width = ruleLen;
            Timeline.gridContainer.style.width = ruleLen;
            Timeline.animContainer_overlay.style.width = ruleLen;
        },

        ChangeFrameRate: function () {

            var ddlframerate = document.getElementById("ddlframerate");
            ScaleUtil.AnimFrameRate = ddlframerate.value;

        },

        SetFrameRate: function () {

            var framerate = document.getElementById("txtframerate").value;

            if (framerate.indexOf('.') >= 0) {
                alert("Please enter framerate as whole number.");
                return false;
            }
            if (parseInt(framerate) < 1 || parseInt(framerate) > 30) {
                alert("Please enter framerate within the range 1-30.");
