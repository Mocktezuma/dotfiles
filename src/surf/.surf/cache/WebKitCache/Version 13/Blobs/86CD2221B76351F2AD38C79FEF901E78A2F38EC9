            evt.configure();
        }
        else if (evt.type == "showhidelayer") {
            evt.configure();
        }
        else if (evt.type == 'video') {
            evt.configure();
        }
        else if (evt.type == 'changeimage') {
            evt.configure();
        }
        else if (evt.type == 'changetext') {
            evt.configure();
        }
        else if (evt.type == 'pfa') {
            evt.configure();
