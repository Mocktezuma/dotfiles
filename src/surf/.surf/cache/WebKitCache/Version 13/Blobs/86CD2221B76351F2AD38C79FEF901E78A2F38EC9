    this.time = "";
    this.pageno = 1;
    this.action = "";
    this.layername = "";
    this.tags = new Array();
    this.tags_sty = new Array();
    this.tags_cls = new Array();
    this.playmode = "";
    this.status = "I";
    //
    this.duration = 0;
    this.startTime = 0;
    this.endTime = 0;
    this.delay = 0;
    this.playstate = 'running';
    this.animstate = "E";
    this.loop = 1;


    this.initobj = function (evt) {
        this.tagname = "";
        this.etype = evt[1];
        this.time = "";
        this.pageno = evt[2];
        this.action = evt[3];
        this.layername = evt[4];
        this.tags = new Array();
        this.tags_sty = new Array();
        this.tags_cls = new Array();
        this.playmode = evt[5];




    }
    this.configure = function () {

        for (var i = 0; i < JSONLayers.p.length; i++) {
            if (JSONLayers.p[i].n != this.pageno) continue;

            var lgid = ""; var cLlyrObj = null;
            var lyr = JSONLayers.p[i].l;
            for (var l = 0; l < lyr.length; l++) {
                if (lyr[l].n != this.layername) continue;
                lgid = lyr[l].g;
                cLlyrObj = lyr[l];
                break;
            }

            if (lgid != "") {
                var groupLayers = [];
                for (var l = 0; l < lyr.length; l++) {
                    if (lyr[l].g != lgid || lyr[l].n == this.layername) continue;
                    groupLayers.push(lyr[l]);
                }

                for (var g = 0; g < groupLayers.length; g++) {
                    groupLayers[g].ov = groupLayers[g].v;
                    groupLayers[g].orc = groupLayers[g].oc;
                }
            }


            cLlyrObj.ov = cLlyrObj.v;
            cLlyrObj.orc = cLlyrObj.oc;
            break;
        }
    }
    /*this.execute = function () {
        PL.showHideLayers(this.action, this.layername, this.pageno);
        this.status = "S";
    }
    this.restore = function () {
        PL.restoreLayers(this.layername, this.pageno);
    }*/
    ///~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    this.updateDelay = function (currentpx) { }

    this.generateCss = function () { }

    this.restore = function () {
        this.restoreLayers(this.layername, this.pageno);
        this.status = "I";
    }

    this.SetEndFrame = function () {

        if (this.status == "E") return;

        this.execute();

    }

    this.execute = function () {

        //this.showHideLayers();
        this.showHideLayers(this.action, this.layername, this.pageno);
        this.status = "E";




    }

    this.showHideLayers = function (action, layername, pageno) {
        if (JSONLayers == null || JSONLayers.p.length == 0) return;
        for (var i = 0; i < JSONLayers.p.length; i++) {
            if (JSONLayers.p[i].n != pageno) continue;

            var cLlyrObj = null;
            var lyr = JSONLayers.p[i].l;
            for (var l = 0; l < lyr.length; l++) {
                if (lyr[l].n != layername) continue;
                cLlyrObj = lyr[l];
                break;
            }

            var lgid = cLlyrObj.g;
            if (action == "show" && lgid != "") {
                var groupLayers = [];
                for (var l = 0; l < lyr.length; l++) {
                    if (lyr[l].g != lgid || lyr[l].n == layername) continue;
                    groupLayers.push(lyr[l]);
                }

                for (var g = 0; g < groupLayers.length; g++) {
                    if (groupLayers[g].v == "N") continue;
                    this.showHideLayer("hide", groupLayers[g].lyobj);
                    groupLayers[g].v = "N";
                    groupLayers[g].oc = "Y";
                }
            }

            if (action == "show" && cLlyrObj.v == "Y")
                break;
            else if (action == "hide" && cLlyrObj.v == "N")
                break;

            this.showHideLayer(action, cLlyrObj.lyobj);
            if (action == "show")
                cLlyrObj.v = "Y";
            else if (action == "hide")
                cLlyrObj.v = "N";

            cLlyrObj.oc = "Y";
            break;
        }
    }
    this.showHideLayer = function (action, lyobj) {

        if (lyobj == undefined || lyobj == null || lyobj.length == 0) return;

        if (action == 'show')
            lyobj.setAttribute("style", "display:block;visibility:visible;left:0px;top:0px");
        else if (action == 'hide')
            lyobj.setAttribute("style", "display:block;visibility:hidden;left:-1000px;top:-1000px");

    }
    this.restoreLayers = function (layername, pageno) {
        if (JSONLayers == null || JSONLayers.p.length == 0) return;
        for (var i = 0; i < JSONLayers.p.length; i++) {
            if (JSONLayers.p[i].n != pageno) continue;

            var lgid = ""; var cLlyrObj = null;
            var lyr = JSONLayers.p[i].l;
            for (var l = 0; l < lyr.length; l++) {
                if (lyr[l].n != layername) continue;
                lgid = lyr[l].g;
                cLlyrObj = lyr[l];
                break;
            }

            if (lgid != "") {
                var groupLayers = [];
                for (var l = 0; l < lyr.length; l++) {
                    if (lyr[l].g != lgid || lyr[l].n == layername) continue;
                    groupLayers.push(lyr[l]);
                }

                for (var g = 0; g < groupLayers.length; g++) {
                    if (groupLayers[g].oc != "Y") continue;
                    this.restoreLayer(groupLayers[g]);
                }
            }
            if (cLlyrObj.oc == "Y")
                this.restoreLayer(cLlyrObj);

            break;
        }
    }
    this.restoreLayer = function (cLayerObj) {

        var lyobj = cLayerObj.lyobj;
        if (lyobj == undefined || lyobj == null || lyobj.length == 0) return;

        if (cLayerObj.ov == 'Y')
            lyobj.setAttribute("style", "display:block;visibility:visible;left:0px;top:0px");
        else if (cLayerObj.ov == 'N')
            lyobj.setAttribute("style", "display:block;visibility:hidden;left:-1000px;top:-1000px");

        cLayerObj.v = cLayerObj.ov;
        cLayerObj.oc = cLayerObj.orc;
    }

    ///~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
}
